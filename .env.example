# Optional: override API base for browser fetches (no trailing slash). Leave empty to use
# same-origin `/api` (Next rewrites + route handlers → upstream). Do not set this to the
# real API URL in production or the browser will hit CORS on Vercel.
NEXT_PUBLIC_APP_API_BASE_ENDPOINT=

# Subdirectory deploy (e.g. Netlify at /partners/*): set to /partners — must match Vercel/CI env
# so next.config basePath, fonts, images, and /api fetches stay aligned. Leave empty for root URL.
NEXT_PUBLIC_BASE_PATH=

# Canonical site URL for Open Graph metadata (optional).
NEXT_PUBLIC_SITE_URL=https://assetwise.co.th
